{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID" },
        "email": { "type": "string", "format": "email", "description": "User email address" },
        "displayName": { "type": "string", "description": "User display name" },
        "photoURL": { "type": "string", "description": "User profile photo URL" },
        "createdAt": { "type": "number", "description": "Timestamp of profile creation" }
      },
      "required": ["uid", "email", "displayName", "createdAt"]
    },
    "Quiz": {
      "title": "Quiz",
      "description": "A generated quiz",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "topic": { "type": "string" },
        "difficulty": { "type": "string", "enum": ["Easy", "Medium", "Hard"] },
        "questions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "type": { "type": "string", "enum": ["mcq", "subjective"] },
              "question": { "type": "string" },
              "options": { "type": "array", "items": { "type": "string" } },
              "correctAnswer": { "type": "string" },
              "explanation": { "type": "string" }
            }
          }
        },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "topic", "difficulty", "questions", "createdAt"]
    },
    "QuizResult": {
      "title": "QuizResult",
      "description": "Results of a completed quiz",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "quizId": { "type": "string" },
        "userId": { "type": "string" },
        "answers": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "questionId": { "type": "string" },
              "userAnswer": { "type": "string" },
              "score": { "type": "number" },
              "feedback": { "type": "string" }
            }
          }
        },
        "totalScore": { "type": "number" },
        "maxScore": { "type": "number" },
        "strengths": { "type": "array", "items": { "type": "string" } },
        "weaknesses": { "type": "array", "items": { "type": "string" } },
        "aiFeedback": { "type": "string" },
        "suggestions": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "quizId", "userId", "answers", "totalScore", "maxScore", "createdAt"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "User profiles"
    },
    "/quizzes/{quizId}": {
      "schema": "Quiz",
      "description": "Generated quizzes"
    },
    "/results/{resultId}": {
      "schema": "QuizResult",
      "description": "Quiz results"
    }
  }
}
